generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id               String   @id @default(uuid())
  senderAddress    String
  recipientAddress String
  amount           String
  txHash           String?
  status           String   @default("pending")
  network          String   @default("testnet")
  createdAt        DateTime @default(now())
}
